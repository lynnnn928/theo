# Theo · 环境变量模板
# 复制为 .env 后填入真实值，.env 不入库

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === 数据库 ===
DATABASE_URL=

# === LLM (TokenDance OpenAI 兼容网关) ===
LLM_PROVIDER=tokendance
LLM_BASE_URL=https://tokendance.space/gateway/v1
LLM_API_KEY=
LLM_MODEL_JD=qwen3-max          # JD 解析用快模型
LLM_MODEL_REPORT=deepseek-v4-pro # 报告生成用推理模型

# === Web 搜索 (TokenDance UniFuncs) ===
SEARCH_PROVIDER=unifuncs
SEARCH_BASE_URL=https://tokendance.space/gateway/unifuncs
SEARCH_API_KEY=

# === 部署 ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000
